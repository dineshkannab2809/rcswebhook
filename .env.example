PORT=5000
DOTGO_API_URL=https://api.dotgo.com/rcs/v1
DOTGO_BOT_ID=your_bot_id_here

# OAuth (recommended: token fetched automatically)
DOTGO_AUTH_URL=https://auth.dotgo.com/auth/oauth/token
DOTGO_AUTH_USERNAME=your_dotgo_client_id
DOTGO_AUTH_PASSWORD=your_dotgo_client_secret

# Optional fallback: static bearer token
# DOTGO_API_KEY=your_static_access_token
# DOTGO_SENDER_ID=your_sender_id_here
